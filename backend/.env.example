# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/policy_agent_db

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Sandbox Configuration
SANDBOX_IMAGE=python:3.11-slim
MAX_CONTAINERS=10
DEFAULT_TIMEOUT=300

# Workspace Configuration
WORKSPACE_BASE_PATH=/tmp/policy_agent_workspace

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/policy_agent.log
